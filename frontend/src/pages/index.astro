---
import StormSelector from "../../components/StormSelector";

const apiBaseUrl = import.meta.env.API_BASE_URL;  // Ensure that there's a .env file in the root of the frontend directory

let storms = [];
let hurricanes = [];
let landfall_hurricanes = [];
let state_shape = [];
let error = null;

if (!apiBaseUrl){
	error = "API URL Not Set"
} else {
	// Four API requests to fetch the required data
	try {
		const response = await fetch(`${apiBaseUrl}/storms`);  // Fetch all the storms
		if (!response.ok) {
			throw new Error(`Failed to fetch storms: ${response.statusText}`);
		}
		storms = await response.json();
	} catch (err) {
		error = err instanceof Error ? err.message : String(err);
	}
	
	try {
		const response = await fetch(`${apiBaseUrl}/hurricanes`);  // Fetch all the hurricanes
		if (!response.ok) {
			throw new Error(`Failed to fetch hurricanes: ${response.statusText}`);
		}
		hurricanes = await response.json();
	} catch (err) {
		error = err instanceof Error ? err.message : String(err);
	}
	
	try {
		const response = await fetch(`${apiBaseUrl}/hurricanes/landfall`);  // Fetch all the hurricanes that made landfall in Florida since 1900
		if (!response.ok) {
			throw new Error(`Failed to fetch hurricanes that made landfall: ${response.statusText}`);
		}
		landfall_hurricanes = await response.json();
	} catch (err) {
		error = err instanceof Error ? err.message : String(err);
	}
	
	try {
		const response = await fetch(`${apiBaseUrl}/shape/florida`);  // Fetch the state geometry for Florida for display
		if (!response.ok) {
			throw new Error(`Failed to fetch state shape: ${response.statusText}`);
		}
		state_shape = await response.json();
	} catch (err) {
		error = err instanceof Error ? err.message : String(err);
	}
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<script src="https://kit.fontawesome.com/41add04957.js" crossorigin="anonymous"></script>
		<title>KCC HURDAT2</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
	</head>
	<body>
		<header>
			<h1>Hurricane Tracker</h1>
			{error ? (
				<p>Error: {error}</p>
			) : (
				<div id="cards"> {/* Info cards to display nice to have info */}
					<div id="storms" class="card">
						<i class="fa-solid fa-cloud-bolt fa-xl"></i> {storms.length} Storms
					</div>
					<div id="hurricanes" class="card">
						<i class="fa-solid fa-hurricane fa-xl"></i> {hurricanes.length} Hurricanes
					</div>
					<div id="florida-hurricanes" class="card">
						<img src="/florida.png" alt="Florida" width="20" /> {landfall_hurricanes.length} Hurricanes made landfall in Florida since 1900
					</div>
				</div>
			)}
		</header>
		<div id="app-content">  {/* Primary app content goes in here */}
			<StormSelector 
				storms={landfall_hurricanes}
				stateGeometry={state_shape}
				client:only 
			/> <!-- Only want to pass the hurricanes that made landfall to the selector -->
		</div>
	</body>
</html>

<style is:global>
	html {
		height: 100%;
		margin: 0;
		padding: 0;
		font-family: "Noto Sans", sans-serif;
		background:
			radial-gradient(circle at top left, rgba(255, 255, 255, 0.45), transparent 35%),
			linear-gradient(180deg, #66b2ff 0%, #5aa7fb 28%, #78bbff 58%, #cfe8ff 100%);
			background-attachment: fixed;
	}

	body {
		height: 100%;
		margin: 0;
		padding: 24px;
		display: flex;
		flex-direction: column;
		box-sizing: border-box;
		color: #0f172a;
	}

	header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 20px;
		margin-bottom: 20px;
		flex-wrap: wrap;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 3vw, 2.75rem);
		line-height: 1;
		letter-spacing: -0.04em;
		color: #ffffff;
		text-shadow: 0 8px 24px rgba(15, 23, 42, 0.2);
	}

	#app-content {
		display: flex;
		flex: 1;
		min-height: 0;
		flex-direction: column;
	}

	#cards {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.card {
		display: flex;
		align-items: center;
		padding: 14px 16px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(255, 255, 255, 0.55);
		border-radius: 14px;
		gap: 10px;
		font-weight: 600;
		color: #0f172a;
		box-shadow: 0 12px 32px rgba(15, 23, 42, 0.14);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
	}

	.card img {
		display: block;
	}

	#storm-wrapper {
		display: flex;
		align-items: stretch;
		justify-content: space-between;
		gap: 16px;
		padding: 16px;
		margin-bottom: 16px;
		background: rgba(255, 255, 255, 0.74);
		border: 1px solid rgba(255, 255, 255, 0.55);
		border-radius: 18px;
		box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		flex-wrap: wrap;
	}

	#storm-selector-layout {
		flex: 1;
		display: flex;
		flex-direction: column;
		min-height: 0;
	}

	#map-wrapper {
		flex: 1;
		min-height: 400px;
		border: 1px solid rgba(15, 23, 42, 0.12);
		border-radius: 20px;
		box-shadow: 0 20px 48px rgba(15, 23, 42, 0.18);
		overflow: hidden;
		background: rgba(255, 255, 255, 0.55);
	}

	#storm-selector {
		padding: 12px 14px;
		border-radius: 12px;
		border: 1px solid rgba(15, 23, 42, 0.14);
		background: rgba(255, 255, 255, 0.92);
		font: inherit;
		font-weight: 600;
		color: #0f172a;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
	}

	#storm-selector:focus {
		outline: 2px solid rgba(37, 99, 235, 0.35);
		outline-offset: 2px;
	}

	#selector-wrapper {
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 260px;
	}

	#selector-label {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #475569;
	}

	#storm-info {
		display: flex;
		align-items: stretch;
		gap: 12px;
		flex-wrap: wrap;
	}

	#storm-info p {
		margin: 0;
		padding: 12px 14px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(15, 23, 42, 0.08);
		font-weight: 500;
		box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
	}

	#storm-info p span {
		display: block;
		margin-bottom: 4px;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #475569;
	}

	@media (max-width: 900px) {
		body {
			padding: 16px;
		}

		header {
			margin-bottom: 16px;
		}

		#cards {
			justify-content: flex-start;
		}

		#storm-wrapper {
			padding: 14px;
		}

		#selector-wrapper {
			min-width: 100%;
		}

		#storm-info {
			width: 100%;
		}

		#storm-info p {
			flex: 1 1 180px;
		}

		#map-wrapper {
			min-height: 320px;
		}
	}
</style>
